{
  "name": "sistema-inventario-lomas",
  "private": true,
  "version": "1.0.3",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vite --open",
    "cloud": "node scripts/watch-deploy.js",
    "dev:cloud": "concurrently --kill-others \"npm run dev\" \"npm run cloud\"",
    "dev:all": "concurrently --kill-others \"npm run dev\" \"npm run start\"",
    "build": "vite build",
    "start": "node server/server.js",
    "start:prod": "node server/init-db.js && node server/server.js",
    "start:public": "concurrently --raw \"node server/server.js\" \"npx cloudflared tunnel --url http://127.0.0.1:3000 --no-autoupdate\"",
    "serve:public": "npm run build && npm run start:public",
    "online": "npm run build && concurrently --raw \"node server/server.js\" \"npx cloudflared tunnel --url http://localhost:3000 --no-autoupdate\"",
    "stop": "Get-Process -Id (Get-NetTCPConnection -LocalPort 3000).OwningProcess | Stop-Process -Force",
    "preview": "vite preview"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.21.0",
    "framer-motion": "^11.5.4",
    "lucide-react": "^0.441.0",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@lucide/lab": "^0.1.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "better-sqlite3": "^11.3.0",
    "concurrently": "^9.2.1",
    "vite": "^5.4.2"
  }
}
